# ============================================
# MindOS AI - Environment Configuration
# ============================================
# Copy this file to .env and fill in your API keys

# OpenAI (Required - GPT-4o + Whisper + Embeddings)
OPENAI_API_KEY=sk-your-openai-api-key-here

# ElevenLabs (Optional - TTS voice output)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL  # "Sarah" warm female voice

# Pinecone (Optional - vector memory, falls back to in-memory)
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=mindos-memory
PINECONE_ENVIRONMENT=us-east-1

# App Configuration
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Model Configuration
WHISPER_MODEL=whisper-1
GPT_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Database
DATABASE_URL=sqlite+aiosqlite:///./mindos.db
